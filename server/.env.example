# ==== VNPay sandbox ====
# Đăng ký merchant sandbox tại https://sandbox.vnpayment.vn/devreg/ để lấy 2 giá trị dưới.
# TUYỆT ĐỐI không commit file .env thật (đã nằm trong .gitignore).
VNP_TMN_CODE=
VNP_SECURE_SECRET=
VNP_HOST=https://sandbox.vnpayment.vn
VNP_TEST_MODE=true

# ==== Server ====
PORT=3000
# Để trống trong môi trường dev: server tự lấy host từ request (LAN IP của máy bạn).
# Khi deploy production, đặt domain công khai có HTTPS, ví dụ: https://api.napthengay.vn
PUBLIC_BASE_URL=

# Deep link quay lại app sau khi thanh toán (khớp "scheme" trong app.json).
APP_RETURN_URL=napthengay://payment-result

# ==== DEV ONLY ====
# true = cấp mã ngay tại Return URL (để test local KHÔNG cần IPN/tunnel).
# KHÔNG BẬT ở production: Return URL có thể bị người dùng giả mạo, chỉ IPN mới đáng tin.
DEV_CONFIRM_ON_RETURN=true
